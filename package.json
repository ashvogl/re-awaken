{
  "name": "re-awaken",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:vault-login": "ob login --email %OBSIDIAN_EMAIL% --password %OBSIDIAN_PASSWORD% --mfa %npm_config_obsidianmfa%",
    "dev:vault-setup": "ob sync-setup --vault Illustris --path illustris --password %VAULT_PASSWORD% && ob sync-config --path illustris --mode mirror-remote --device-name site-auto",
    "prod:vault-login": "ob login --email $OBSIDIAN_EMAIL --password $OBSIDIAN_PASSWORD --mfa $npm_config_obsidianmfa",
    "prod:vault-setup": "ob sync-setup --vault Illustris --path illustris --password $VAULT_PASSWORD && ob sync-config --path illustris --mode mirror-remote --device-name site-auto",
    "vault-sync": "ob sync --path illustris",
    "dev": "compiiile-pro dev",
    "prod": "compiiile-pro build"
  },
  "browserslist": [
    "cover 99.5%"
  ],
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "fast-glob": "^3.3.3",
    "imagemin": "^9.0.1",
    "imagemin-webp": "^8.0.0",
    "postcss-sort-media-queries": "^5.2.0",
    "sass": "^1.85.1",
    "sharp": "^0.33.5",
    "svgo": "^3.3.2",
    "vite": "^6.2.1",
    "vite-plugin-image-optimizer": "^1.1.8"
  },
  "dependencies": {
    "@compiiile/compiiile-pro": "^1.3.2",
    "dotenv": "^17.3.1"
  }
}
